{
    "name": "kadiaak-log-viewer",
    "private": true,
    "type": "module",
    "scripts": {
        "build:css": "tailwindcss -i resources/css/app.css -o resources/dist/app.css --minify",
        "build:js": "esbuild resources/js/app.js --bundle --minify --outfile=resources/dist/app.js",
        "build": "npm run build:css && npm run build:js",
        "dev:css": "tailwindcss -i resources/css/app.css -o resources/dist/app.css --watch",
        "dev:js": "esbuild resources/js/app.js --bundle --outfile=resources/dist/app.js --watch"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.7",
        "autoprefixer": "^10.4.19",
        "esbuild": "^0.21.0",
        "tailwindcss": "^3.4.0"
    },
    "dependencies": {
        "alpinejs": "^3.14.0"
    }
}
