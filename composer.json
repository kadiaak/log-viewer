{
    "name": "kadiaak/log-viewer",
    "description": "A beautiful, fast log viewer for Laravel applications.",
    "keywords": ["laravel", "log", "logs", "log-viewer", "logging", "debug"],
    "license": "MIT",
    "authors": [
        {
            "name": "Kadiaak",
            "email": "hi@kadiaak.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Kadiaak\\LogViewer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kadiaak\\LogViewer\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kadiaak\\LogViewer\\LogViewerServiceProvider"
            ],
            "aliases": {
                "LogViewer": "Kadiaak\\LogViewer\\Facades\\LogViewer"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
